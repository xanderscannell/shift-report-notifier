package com.example.dailyform

import java.time.DayOfWeek

/**
 * Per-user configuration TEMPLATE — these are now just the SEED DEFAULTS.
 *
 * Everything here can be edited in-app from the gear/Settings screen at
 * runtime (those edits are stored in SharedPreferences via Prefs.kt and take
 * precedence). FormConfig only supplies the values a fresh install starts with,
 * so you can either fill them in here or leave the placeholders and set
 * everything up in the app.
 *
 * SETUP: copy this file to FormConfig.kt (same folder) and optionally fill in
 * your values. FormConfig.kt is gitignored, so your personal info stays out of
 * git.
 *
 *   cp FormConfig.kt.example FormConfig.kt
 */
object FormConfig {

    // ===== Reminder schedule =====

    // What time the reminder fires, on a 24-hour clock.
    const val REMINDER_HOUR = 9   // 0-23
    const val REMINDER_MINUTE = 0 // 0-59

    // Which days the reminder fires on. Remove days to skip them (e.g. drop
    // SATURDAY and SUNDAY for weekdays only). Must contain at least one day.
    val REMINDER_DAYS: Set<DayOfWeek> = setOf(
        DayOfWeek.MONDAY,
        DayOfWeek.TUESDAY,
        DayOfWeek.WEDNESDAY,
        DayOfWeek.THURSDAY,
        DayOfWeek.FRIDAY,
        DayOfWeek.SATURDAY,
        DayOfWeek.SUNDAY,
    )

    // ===== Form details =====

    // The long string in your form's URL, between /d/e/ and /viewform:
    //   https://docs.google.com/forms/d/e/FORM_ID_HERE/viewform
    const val FORM_ID = "YOUR_FORM_ID_HERE"

    // Entry IDs: open your form -> "Get pre-filled link", fill a sample
    // response, click "Get link", and read the entry.NNN values out of the URL.
    const val DATE_ENTRY_ID = "entry.0000000000"        // date -> YYYY-MM-DD
    const val TIME_ENTRY_ID = "entry.0000000000"        // time -> HH:mm (24h)
    const val NAME_ENTRY_ID = "entry.0000000000"        // name -> static
    const val PART_OF_DAY_ENTRY_ID = "entry.0000000000" // Morning/Afternoon/Evening

    // Static value submitted for the name field.
    const val YOUR_NAME = "Your Name"

    // Labels for the time-of-day choice. These must EXACTLY match your form's
    // options (same spelling/capitalization) or the choice won't pre-select.
    const val MORNING_LABEL = "Morning"
    const val AFTERNOON_LABEL = "Afternoon"
    const val EVENING_LABEL = "Evening"

    // Hour (0-23) at which each part of the day begins. Buckets are contiguous
    // and Evening wraps past midnight, i.e.:
    //   Morning   = MORNING_START_HOUR   until AFTERNOON_START_HOUR
    //   Afternoon = AFTERNOON_START_HOUR until EVENING_START_HOUR
    //   Evening   = everything else (EVENING_START_HOUR .. MORNING_START_HOUR)
    // Keep them in ascending order: morning < afternoon < evening.
    const val MORNING_START_HOUR = 5
    const val AFTERNOON_START_HOUR = 14
    const val EVENING_START_HOUR = 19
}
